# === Paths ===
INPUT_DIR=Input Covers
OUTPUT_DIR=Output Covers
TMP_DIR=tmp
DATA_DIR=data
CONFIG_DIR=config

# Optional config file name overrides (resolved under CONFIG_DIR)
PROMPTS_FILE=book_prompts.json
BOOK_CATALOG_FILE=book_catalog.json
PROMPT_TEMPLATES_FILE=prompt_templates.json
PROMPT_LIBRARY_FILE=prompt_library.json

# === Provider + Model Selection ===
AI_PROVIDER=openrouter
AI_MODEL=openrouter/google/gemini-2.5-flash-image
ALL_MODELS=openrouter/google/gemini-2.5-flash-image,openrouter/openai/gpt-5-image-mini,openrouter/openai/gpt-5-image,fal/fal-ai/flux-2/klein/4b,fal/fal-ai/flux-2,openai/gpt-image-1-mini,openai/gpt-image-1,google/gemini-2.5-flash-image,google/gemini-3-pro-image-preview
OUTBOUND_ALLOWLIST_DOMAINS=api.openai.com,openrouter.ai,fal.run,generativelanguage.googleapis.com

# === API Keys ===
OPENROUTER_API_KEY=
FAL_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# === LLM (Prompt 11A enrichment/intelligent prompts) ===
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MAX_TOKENS=2000
LLM_COST_PER_1K_TOKENS=0.003

# === Google Drive ===
GDRIVE_SOURCE_FOLDER_ID=1ybFYDJk7Y3VlbsEjRAh1LOfdyVsHM_cS
GDRIVE_OUTPUT_FOLDER_ID=1CWxCE3dP2AmQRy-w9MowP0J7AWNuAYdW
GDRIVE_MOCKUPS_FOLDER_ID=
GDRIVE_AMAZON_FOLDER_ID=
GDRIVE_SOCIAL_FOLDER_ID=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_PATH=

# === Generation Controls ===
VARIANTS_PER_COVER=5
MAX_GENERATION_VARIANTS=50
BATCH_CONCURRENCY=1
REQUEST_DELAY=1.0
MAX_RETRIES=3
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_COOLDOWN_SECONDS=90

# Optional per-provider request pacing overrides (seconds)
OPENROUTER_REQUEST_DELAY=1.0
FAL_REQUEST_DELAY=1.0
OPENAI_REQUEST_DELAY=1.0
GOOGLE_REQUEST_DELAY=1.0

# === Image Output ===
GEN_WIDTH=1024
GEN_HEIGHT=1024
GEN_OUTPUT_FORMAT=png

# === Quality + Cost ===
MIN_QUALITY_SCORE=0.6
MAX_COST_USD=200.00

# === Scope Controls ===
BOOK_SCOPE_LIMIT=20
MAX_EXPORT_VARIANTS=20
COMPOSITE_MAX_INVALID_VARIANTS=0
SLO_WINDOW_DAYS=7
SLO_ALERT_COOLDOWN_SECONDS=900
SLO_ALERT_LEVELS=breached,at_risk
SLO_MONITOR_INTERVAL_SECONDS=300

# === Web API Controls ===
WEB_API_TOKEN=
WEB_RATE_LIMIT_PER_MINUTE=120
ALLOW_SYNC_GENERATION=0
JOB_WORKERS=2
JOB_WORKER_MODE=external
JOB_WORKER_HEARTBEAT_PATH=data/worker_heartbeat.json
JOB_WORKER_HEARTBEAT_STALE_SECONDS=120
JOB_STALE_RECOVERY_SECONDS=900
JOB_STALE_RECOVERY_RETRY_DELAY_SECONDS=2.0
JOBS_DB_PATH=data/jobs.sqlite3
STATE_DB_PATH=data/state.sqlite3
AUDIT_LOG_SECRET=
